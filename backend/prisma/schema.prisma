generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  OWNER
  ADMIN
}

enum Plan {
  GRATIS
  PRO
}

enum ThemePreset {
  SUNSET
  FOREST
  OCEAN
  BERRY
  MONO
}

enum MenuCardStyle {
  ROUNDED
  SOFT
  MINIMAL
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  supabaseId String      @unique @db.Uuid
  role       Role        @default(OWNER)
  restaurant Restaurant?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([supabaseId])
  @@map("users")
}

model Restaurant {
  id          String         @id @default(cuid())
  slug        String         @unique @db.VarChar(100)
  name        String         @db.VarChar(255)
  description String?        @db.Text
  address     String         @db.VarChar(500)
  whatsapp    String         @db.VarChar(20)
  category    String         @db.VarChar(50)
  logoUrl     String?        @db.VarChar(500)
  coverUrl    String?        @db.VarChar(500)
  themePreset ThemePreset    @default(SUNSET)
  menuStyle   MenuCardStyle  @default(ROUNDED)
  plan        Plan           @default(GRATIS)
  latitude      Float?
  longitude     Float?

  // Personalización avanzada
  primaryColor   String?  @db.VarChar(7)
  secondaryColor String?  @db.VarChar(7)
  fontFamily     String?  @db.VarChar(50)
  menuLayout     String?  @db.VarChar(10)
  bannerText     String?  @db.VarChar(200)

  // Redes sociales
  instagram      String?  @db.VarChar(100)
  tiktok         String?  @db.VarChar(100)
  facebook       String?  @db.VarChar(100)

  // Horarios (JSON serializado)
  schedule       String?  @db.Text

  isActive    Boolean        @default(true)
  isClosed    Boolean        @default(false)
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String         @unique
  categories  MenuCategory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([slug])
  @@index([category])
  @@index([plan])
  @@index([isActive])
  @@map("restaurants")
}

model MenuCategory {
  id           String     @id @default(cuid())
  name         String     @db.VarChar(100)
  description  String?    @db.Text
  order        Int        @default(0)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("menu_categories")
}

model MenuItem {
  id             String       @id @default(cuid())
  name           String       @db.VarChar(255)
  description    String?      @db.Text
  price          Decimal      @db.Decimal(10, 2)
  imageUrl       String?      @db.VarChar(500)
  badge          String?      @db.VarChar(20)
  /** JSON: { extras?: { id, name, price }[], removables?: string[] } */
  customization  Json?
  isAvailable    Boolean      @default(true)
  order          Int          @default(0)
  category       MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([categoryId])
  @@index([isAvailable])
  @@map("menu_items")
}
