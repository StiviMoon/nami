# Public frontend config
# URL del API (backend). El front corre en el puerto 4000 (ver package.json); el API suele ser 8001.
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_WHATSAPP_SALES=573235018878

# PWA: el service worker se registra solo en producción (npm run build && npm start).
# En `next dev` no se registra para evitar conflictos con HMR.
